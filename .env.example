# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Convex
NEXT_PUBLIC_CONVEX_URL=

# Google Business Profile API
# 1. Create a Google Cloud Project: https://console.cloud.google.com
# 2. Enable My Business API: https://console.cloud.google.com/apis/library/mybusiness.googleapis.com
# 3. Create a Service Account: https://console.cloud.google.com/iam-admin/serviceaccounts
# 4. Generate a JSON key and set GOOGLE_SERVICE_ACCOUNT_JSON to its content
# 5. OR set GOOGLE_ACCESS_TOKEN to a valid OAuth2 access token
# 6. Set GOOGLE_ACCOUNT_ID to your My Business Account ID
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ACCESS_TOKEN=
GOOGLE_ACCOUNT_ID=

# Yelp Business API
# 1. Get API key: https://www.yelp.com/developers
# 2. Create an app to get your API key
# 3. Yelp's partner API requires business partnership agreement for full functionality
YELP_API_KEY=

# Facebook Graph API (Pages + Instagram Business)
# 1. Create Facebook App: https://developers.facebook.com/apps
# 2. Add Pages product and Instagram product
# 3. Generate access token with permissions: pages_manage_metadata, instagram_basic,instagram_manage_insights
# 4. Requires Facebook Business Account
# 5. Requires page to exist: Create at https://www.facebook.com/pages/
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# BrightLocal (for directory submission)
BRIGHTLOCAL_API_KEY=
BRIGHTLOCAL_API_SECRET=

# Sentry
SENTRY_DSN=

# PostHog (optional analytics)
NEXT_PUBLIC_POSTHOG_KEY=
